# E-Inventory — cache behavior (requires Apache AllowOverride + mod_headers)
<IfModule mod_headers.c>
  # SPA / HTML: avoid stale UI after deploy (theme, background, etc.)
  <FilesMatch "\.(html|htm)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header unset Expires
  </FilesMatch>

  # CSS / JS: short cache (HTML uses ?v= to bust when you change files)
  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "public, max-age=3600"
  </FilesMatch>

  # JSON API responses (if ever served as static files)
  <FilesMatch "\.json$">
    Header set Cache-Control "no-cache"
  </FilesMatch>
</IfModule>
